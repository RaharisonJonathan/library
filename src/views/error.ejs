<%- include('partials/header') %>

<div class="error-container">
  <div class="error-card">
    <div class="error-icon">
      <i class="fa-solid fa-circle-exclamation"></i>
    </div>
    <h1>Erreur <%= locals.status || 500 %></h1>
    <p class="error-message"><%= locals.message || "Une erreur inattendue s'est produite." %></p>
    <div class="incident-alert">
      <i class="fa-solid fa-info-circle"></i>
      <span>L'incident a été enregistré dans notre système qualité (ITIL). Un administrateur a été notifié.</span>
    </div>
    <a href="/dashboard" class="btn btn-primary">
      <i class="fa-solid fa-house"></i> Retourner au tableau de bord
    </a>
  </div>
</div>

<style>
  .error-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 3rem 0;
  }

  .error-card {
    background: var(--panel-bg);
    border: 1px solid var(--panel-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 3rem 2rem;
    border-radius: 20px;
    width: 100%;
    max-width: 500px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3),
                0 0 40px rgba(239, 68, 68, 0.1);
  }

  .error-icon {
    font-size: 4rem;
    color: var(--danger);
    margin-bottom: 1.5rem;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.9; }
    50% { transform: scale(1.05); opacity: 1; text-shadow: 0 0 20px rgba(239, 68, 68, 0.4); }
    100% { transform: scale(1); opacity: 0.9; }
  }

  h1 {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(to right, #fca5a5, #ef4444);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .error-message {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .incident-alert {
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 10px;
    padding: 0.8rem 1rem;
    font-size: 0.85rem;
    color: #c7d2fe;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-align: left;
    margin-bottom: 2rem;
    line-height: 1.4;
  }

  .incident-alert i {
    font-size: 1.2rem;
    color: var(--primary);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.8rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--primary);
    border: none;
    color: #fff;
    box-shadow: 0 4px 15px var(--primary-glow);
  }

  .btn-primary:hover {
    background: var(--primary-hover);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
  }
</style>

<%- include('partials/footer') %>
