<script>
  // Initialisation au chargement
  document.addEventListener('DOMContentLoaded', () => {
    fetchBooks();
    fetchLoans();
  });

  // Utilitaire d'alertes Toasts
  function showToast(message, type = 'success') {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    toast.innerHTML = `
      <i class="fa-solid ${type === 'success' ? 'fa-circle-check text-success' : 'fa-circle-exclamation'}" style="color: ${type === 'success' ? 'var(--success)' : 'var(--danger)'}"></i>
      <span>${message}</span>
    `;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transition = 'opacity 0.5s';
      setTimeout(() => toast.remove(), 500);
    }, 4000);
  }

  // --- CATALOGUE DES LIVRES ---
  async function fetchBooks() {
    try {
      const search = document.getElementById('catalog-search').value;
      const response = await fetch(`/api/books?search=${encodeURIComponent(search)}`, {
        headers: { 'Accept': 'application/json' }
      });
      const data = await response.json();
      
      const container = document.getElementById('books-list-container');
      container.innerHTML = '';

      if (data.books.length === 0) {
        container.innerHTML = `<div style="text-align: center; color: var(--text-muted); padding: 2rem;">Aucun livre trouvé.</div>`;
        return;
      }

      data.books.forEach(book => {
        const isAvailable = book.available_copies > 0;
        const stockClass = isAvailable ? 'stock-in' : 'stock-out';
        const stockText = isAvailable ? `${book.available_copies} dispo(s) / ${book.total_copies}` : 'Rupture de stock';

        let actionBtns = '';
        <% if (user.role === 'lecteur') { %>
          if (isAvailable) {
            actionBtns = `
              <button class="btn btn-sm btn-primary" onclick="borrowBook(${book.id})" id="borrow-btn-${book.id}">
                <i class="fa-solid fa-bookmark"></i> Emprunter
              </button>`;
          } else {
            actionBtns = `<button class="btn btn-sm" disabled style="background: rgba(255,255,255,0.05); color: var(--text-muted);">Indisponible</button>`;
          }
        <% } else if (user.role === 'bibliothecaire' || user.role === 'admin') { %>
          actionBtns = `
            <button class="btn btn-sm btn-primary-outline" onclick="openEditBookModal(${JSON.stringify(book).replace(/"/g, '&quot;')})" id="edit-btn-${book.id}">
              <i class="fa-solid fa-pen"></i> Modifier
            </button>
            <button class="btn btn-sm btn-danger-outline" onclick="deleteBook(${book.id})" id="delete-btn-${book.id}">
              <i class="fa-solid fa-trash"></i>
            </button>
          `;
        <% } %>

        container.innerHTML += `
          <div class="book-card" id="book-card-${book.id}">
            <div class="book-info">
              <span class="book-title">${book.title}</span>
              <span class="book-author">par ${book.author}</span>
              <div class="book-meta">
                <span>ISBN: ${book.isbn}</span>
                <span>Catégorie: ${book.category}</span>
                <span class="book-stock ${stockClass}">${stockText}</span>
              </div>
            </div>
            <div class="book-actions">
              ${actionBtns}
            </div>
          </div>
        `;
      });
    } catch (err) {
      console.error(err);
      showToast("Erreur lors de la récupération du catalogue.", 'error');
    }
  }

  // --- GESTION DES EMPRUNTS ---
  async function fetchLoans() {
    try {
      const response = await fetch('/api/loans', {
        headers: { 'Accept': 'application/json' }
      });
      const loans = await response.json();
      
      const container = document.getElementById('loans-list-container');
      container.innerHTML = '';

      if (loans.length === 0) {
        container.innerHTML = `<div style="text-align: center; color: var(--text-muted); padding: 2rem;">Aucun emprunt enregistré.</div>`;
        return;
      }

      loans.forEach(loan => {
        const formattedLoanDate = new Date(loan.loan_date).toLocaleDateString('fr-FR');
        const formattedDueDate = new Date(loan.due_date).toLocaleDateString('fr-FR');
        const formattedReturnDate = loan.return_date ? new Date(loan.return_date).toLocaleDateString('fr-FR') : null;
        
        let returnBtn = '';
        if (loan.status === 'actif' || loan.status === 'en_retard') {
          returnBtn = `
            <button class="btn btn-sm btn-primary-outline" onclick="returnBook(${loan.id})" id="return-btn-${loan.id}" style="margin-top: 0.5rem;">
              <i class="fa-solid fa-rotate-left"></i> Retourner le livre
            </button>`;
        }

        const usernameTag = loan.username ? `<span class="loan-user"><i class="fa-solid fa-user"></i> ${loan.username}</span>` : '';

        container.innerHTML += `
          <div class="loan-card status-${loan.status}" id="loan-card-${loan.id}">
            <span class="loan-badge loan-badge-${loan.status}">${loan.status.toUpperCase()}</span>
            <div class="loan-header">
              <span class="loan-title">${loan.title}</span>
              ${usernameTag}
            </div>
            <div class="loan-dates">
              <span>Emprunté le : <strong>${formattedLoanDate}</strong></span>
              <span>Date limite de retour : <strong>${formattedDueDate}</strong></span>
              ${formattedReturnDate ? `<span>Retourné le : <strong>${formattedReturnDate}</strong></span>` : ''}
            </div>
            ${returnBtn}
          </div>
        `;
      });
    } catch (err) {
      console.error(err);
      showToast("Erreur lors de la récupération des emprunts.", 'error');
    }
  }

  async function borrowBook(bookId) {
    try {
      const response = await fetch('/api/loans', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ bookId })
      });
      const data = await response.json();
      
      if (response.ok) {
        showToast(data.message);
        fetchBooks();
        fetchLoans();
      } else {
        showToast(data.error, 'error');
      }
    } catch (err) {
      showToast("Une erreur est survenue lors de la tentative d'emprunt.", 'error');
    }
  }

  async function returnBook(loanId) {
    try {
      const response = await fetch('/api/loans/return', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ loanId })
      });
      const data = await response.json();
      
      if (response.ok) {
        showToast(data.message);
        fetchBooks();
        fetchLoans();
      } else {
        showToast(data.error, 'error');
      }
    } catch (err) {
      showToast("Une erreur est survenue lors du retour.", 'error');
    }
  }

  // --- MODAL & LOGIQUE CRUD LIVRES ---
  <% if (user.role === 'bibliothecaire' || user.role === 'admin') { %>
    function openAddBookModal() {
      document.getElementById('modal-title').textContent = "Ajouter un nouveau livre";
      document.getElementById('book-id').value = '';
      document.getElementById('book-title').value = '';
      document.getElementById('book-author').value = '';
      document.getElementById('book-isbn').value = '';
      document.getElementById('book-category').value = '';
      document.getElementById('book-copies').value = '1';
      document.getElementById('book-modal').style.display = 'flex';
    }

    function openEditBookModal(book) {
      document.getElementById('modal-title').textContent = "Modifier le livre";
      document.getElementById('book-id').value = book.id;
      document.getElementById('book-title').value = book.title;
      document.getElementById('book-author').value = book.author;
      document.getElementById('book-isbn').value = book.isbn;
      document.getElementById('book-category').value = book.category;
      document.getElementById('book-copies').value = book.total_copies;
      document.getElementById('book-modal').style.display = 'flex';
    }

    function closeBookModal() {
      document.getElementById('book-modal').style.display = 'none';
    }

    async function saveBook(event) {
      event.preventDefault();
      const id = document.getElementById('book-id').value;
      const title = document.getElementById('book-title').value;
      const author = document.getElementById('book-author').value;
      const isbn = document.getElementById('book-isbn').value;
      const category = document.getElementById('book-category').value;
      const total_copies = document.getElementById('book-copies').value;

      const url = id ? `/api/books/${id}` : '/api/books';
      const method = id ? 'PUT' : 'POST';

      try {
        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ title, author, isbn, category, total_copies })
        });
        const data = await response.json();

        if (response.ok) {
          showToast(data.message);
          closeBookModal();
          fetchBooks();
          fetchLoans();
        } else {
          showToast(data.error, 'error');
        }
      } catch (err) {
        showToast("Erreur lors de l'enregistrement du livre.", 'error');
      }
    }

    async function deleteBook(id) {
      if (!confirm("Voulez-vous vraiment supprimer ce livre ?")) return;

      try {
        const response = await fetch(`/api/books/${id}`, {
          method: 'DELETE',
          headers: { 'Accept': 'application/json' }
        });
        const data = await response.json();

        if (response.ok) {
          showToast(data.message);
          fetchBooks();
        } else {
          showToast(data.error, 'error');
        }
      } catch (err) {
        showToast("Erreur lors de la suppression.", 'error');
      }
    }
  <% } %>

  // --- ACTIONS ITIL SIMULÉES ---
  <% if (user.role === 'admin') { %>
    async function simulateIncident(type) {
      const resultBox = document.getElementById('itil-result-box');
      resultBox.style.display = 'block';
      resultBox.innerHTML = 'Simulation en cours...';

      try {
        const response = await fetch(`/api/itil/simulate-incident?type=${type}`);
        const data = await response.json();
        
        if (response.ok) {
          resultBox.innerHTML = `[ITIL INCIDENT CONTROL]\nStatus: OK\nMessage: ${data.message}\nLogs enregistrés:\n${data.logs}`;
          showToast("Incident simulé enregistré !");
        } else {
          resultBox.innerHTML = `[ITIL ERROR]\nStatus: ${response.status}\nMessage: ${data.error}`;
          showToast(data.error, 'error');
        }
      } catch (err) {
        resultBox.innerHTML = `[ITIL FATAL EXCEPTION] Connexion perdue ou plantage.`;
        showToast("Exception système simulée !", 'error');
      }
    }

    async function simulateChange() {
      const resultBox = document.getElementById('itil-result-box');
      resultBox.style.display = 'block';
      resultBox.innerHTML = 'Traitement de la demande de changement (RFC)...';

      try {
        const response = await fetch('/api/itil/simulate-change', { method: 'POST' });
        const data = await response.json();

        if (response.ok) {
          resultBox.innerHTML = `[ITIL CHANGE MANAGEMENT (RFC)]\nStatus: APPRÉCIÉ & DÉPLOYÉ\nMessage: ${data.message}\nNotes: ${data.notes}`;
          showToast("Changement de base de données effectué avec succès !");
        } else {
          resultBox.innerHTML = `[ITIL CHANGE ERROR]\nStatus: ${response.status}\nMessage: ${data.error}`;
          showToast(data.error, 'error');
        }
      } catch (err) {
        resultBox.innerHTML = `[ITIL FATAL EXCEPTION] Échec du déploiement de la RFC.`;
        showToast("Échec du changement.", 'error');
      }
    }
  <% } %>
</script>

<%- include('partials/footer') %>
