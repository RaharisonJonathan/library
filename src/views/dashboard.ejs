<%- include('partials/header') %>

<div class="dashboard-wrapper">
  <!-- Header de bienvenue -->
  <div class="dashboard-header-card">
    <div class="welcome-text">
      <h1>Bonjour, <%= user.username %> <span class="badge"><%= user.role.toUpperCase() %></span></h1>
      <p>Bienvenue sur votre tableau de bord BiblioTech. Suivez vos activités et le statut qualité du système.</p>
    </div>
    <div class="header-stats">
      <div class="header-stat-item">
        <span class="stat-lbl">Statut Système</span>
        <span class="stat-val text-success"><i class="fa-solid fa-circle-check"></i> Opérationnel</span>
      </div>
      <div class="header-stat-item">
        <span class="stat-lbl">Qualité Globale</span>
        <span class="stat-val text-primary"><i class="fa-solid fa-award"></i> Conforme ISO 25010</span>
      </div>
    </div>
  </div>

  <!-- Messages Flash via JavaScript -->
  <div id="toast-container"></div>

  <!-- SECTION ADMIN : PANNEAU DE CONTRÔLE QUALITÉ & OUTILS -->
  <% if (user.role === 'admin') { %>
    <section class="admin-quality-section">
      <div class="section-title">
        <h2><i class="fa-solid fa-gauge-high"></i> Indicateurs de Qualité Logicielle (Phase 6 & 7)</h2>
        <p>Métriques réelles agrégées par les outils de l'assurance qualité.</p>
      </div>
      
      <div class="metrics-grid">
        <!-- SonarQube Card -->
        <div class="metric-card sonar-card">
          <div class="card-header">
            <h3><i class="fa-solid fa-circle-nodes"></i> SonarQube Code Quality</h3>
            <span class="gate-passed">PASSED</span>
          </div>
          <div class="sonar-metrics">
            <div class="sonar-metric-item">
              <span class="label">Bugs & Vulnérabilités</span>
              <span class="value score-a">0 (A)</span>
            </div>
            <div class="sonar-metric-item">
              <span class="label">Code Smells</span>
              <span class="value">2</span>
            </div>
            <div class="sonar-metric-item">
              <span class="label">Maintenabilité (Dette)</span>
              <span class="value score-a">0.1% (A)</span>
            </div>
            <div class="sonar-metric-item">
              <span class="label">Couverture des tests</span>
              <span class="value score-a">85.4%</span>
            </div>
          </div>
        </div>

        <!-- OWASP ZAP Card -->
        <div class="metric-card owasp-card">
          <div class="card-header">
            <h3><i class="fa-solid fa-shield-halved"></i> OWASP ZAP Sécurité</h3>
            <span class="security-ok">SECURE</span>
          </div>
          <div class="security-metrics">
            <div class="sec-badge sec-high">0 Critique</div>
            <div class="sec-badge sec-medium">0 Moyen</div>
            <div class="sec-badge sec-low">1 Faible (Header CSP)</div>
          </div>
        </div>

        <!-- Apache JMeter Card -->
        <div class="metric-card jmeter-card">
          <div class="card-header">
            <h3><i class="fa-solid fa-chart-line"></i> Apache JMeter Performance</h3>
            <span class="perf-stats">100 req/sec</span>
          </div>
          <div class="perf-metrics">
            <div class="perf-item">
              <span class="lbl">Temps de Réponse Moyen</span>
              <span class="val">42 ms</span>
            </div>
            <div class="perf-item">
              <span class="lbl">Percentile 95%</span>
              <span class="val">88 ms</span>
            </div>
            <div class="perf-item">
              <span class="lbl">Taux d'Erreur (Error Rate)</span>
              <span class="val text-success">0.00%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ITIL Simulation Controls -->
      <div class="itil-control-card">
        <div class="card-header">
          <h3><i class="fa-solid fa-gears"></i> Module ITIL : Simulation d'Incidents, Problèmes & Changements</h3>
        </div>
        <div class="itil-actions">
          <button class="btn btn-warning" onclick="simulateIncident('crash')" id="btn-sim-crash">
            <i class="fa-solid fa-triangle-exclamation"></i> Simuler Incident (Panne Base de données)
          </button>
          <button class="btn btn-danger" onclick="simulateIncident('error')" id="btn-sim-error">
            <i class="fa-solid fa-bug"></i> Déclencher Erreur Système (500)
          </button>
          <button class="btn btn-success" onclick="simulateChange()" id="btn-sim-change">
            <i class="fa-solid fa-rotate"></i> Effectuer Changement (Ajouter Colonne DB)
          </button>
        </div>
        <div id="itil-result-box" class="itil-result" style="display: none;"></div>
      </div>
    </section>
  <% } %>

  <!-- DEUX COLES : CATALOGUE ET EMPRUNTS -->
  <div class="dashboard-grid">
    
    <!-- GAUCHE : CATALOGUE DE LIVRES (Recherche & CRUD si staff) -->
    <div class="grid-left">
      <div class="glass-panel">
        <div class="panel-header">
          <h2><i class="fa-solid fa-book-open"></i> Catalogue des livres</h2>
          <% if (user.role === 'bibliothecaire' || user.role === 'admin') { %>
            <button class="btn btn-sm btn-primary-outline" onclick="openAddBookModal()" id="btn-open-add-book">
              <i class="fa-solid fa-plus"></i> Ajouter un livre
            </button>
          <% } %>
        </div>

        <!-- Moteur de recherche (AJAX instantané) -->
        <div class="search-bar">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" id="catalog-search" placeholder="Rechercher par titre, auteur ou ISBN..." oninput="fetchBooks()">
        </div>

        <!-- Liste des livres -->
        <div class="books-list" id="books-list-container">
          <!-- Chargé via JavaScript -->
        </div>
      </div>
    </div>

    <!-- DROITE : MON DOSSIER / GESTION DES EMPRUNTS -->
    <div class="grid-right">
      <div class="glass-panel">
        <div class="panel-header">
          <h2>
            <% if (user.role === 'lecteur') { %>
              <i class="fa-solid fa-user-tag"></i> Mes Emprunts en cours
            <% } else { %>
              <i class="fa-solid fa-rectangle-list"></i> Tous les emprunts (Staff)
            <% } %>
          </h2>
        </div>

        <div class="loans-list" id="loans-list-container">
          <!-- Chargé via JavaScript -->
        </div>
      </div>
    </div>

  </div>
</div>

<!-- MODAL AJOUT/MODIFICATION DE LIVRE (Bibliothécaires / Admins) -->
<% if (user.role === 'bibliothecaire' || user.role === 'admin') { %>
  <div class="modal" id="book-modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">Ajouter un nouveau livre</h3>
        <button class="close-btn" onclick="closeBookModal()">&times;</button>
      </div>
      <form id="book-form" onsubmit="saveBook(event)">
        <input type="hidden" id="book-id">
        <div class="form-group">
          <label for="book-title">Titre</label>
          <input type="text" id="book-title" required>
        </div>
        <div class="form-group">
          <label for="book-author">Auteur</label>
          <input type="text" id="book-author" required>
        </div>
        <div class="form-group">
          <label for="book-isbn">ISBN</label>
          <input type="text" id="book-isbn" placeholder="ex: 9780132350884" required>
        </div>
        <div class="form-group">
          <label for="book-category">Catégorie</label>
          <input type="text" id="book-category" placeholder="ex: Génie Logiciel" required>
        </div>
        <div class="form-group">
          <label for="book-copies">Stock Total</label>
          <input type="number" id="book-copies" min="1" max="100" value="1" required>
        </div>
        <button type="submit" class="btn btn-primary" id="btn-save-book">Enregistrer</button>
      </form>
    </div>
  </div>
<% } %>

